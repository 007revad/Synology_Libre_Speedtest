#!/bin/bash

PKG_NAME=$(basename "$SYNOPKG_PKGDEST")
PKG_DEST="$SYNOPKG_PKGDEST"
VAR_DIR="/var/packages/${PKG_NAME}/var"
WEBMAN_LINK="/usr/syno/synoman/webman/3rdparty/${PKG_NAME}"
UI_DIR="${PKG_DEST}/ui"
LOG_FILE="${VAR_DIR}/install.log"

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE" 2>/dev/null || echo "$1"
}

# Create var directory for logs and pidfile
mkdir -p "$VAR_DIR" || { echo "Error: Failed to create VAR_DIR"; exit 1; }
log_message "Post-installation starting for package: ${PKG_NAME}"

# Create webman/3rdparty symlink so DSM nginx serves the UI
if ln -sf "${UI_DIR}" "${WEBMAN_LINK}"; then
    log_message "Created webman symlink: ${WEBMAN_LINK} -> ${UI_DIR}"
else
    log_message "Error: Failed to create webman symlink"
    exit 1
fi

# Create cgi-bin directory with symlinks to backend CGI scripts
# Python's CGIHTTPRequestHandler only executes scripts in cgi-bin/
mkdir -p "${UI_DIR}/cgi-bin" || { log_message "Error: Failed to create cgi-bin dir"; exit 1; }

for cgi in garbage.cgi empty.cgi getIP.cgi; do
    ln -sf "../backend/${cgi}" "${UI_DIR}/cgi-bin/${cgi}" && \
        log_message "Created cgi-bin symlink: ${cgi}" || \
        log_message "Warning: Failed to create cgi-bin symlink for ${cgi}"
done

# Set execute permissions on CGI scripts
for cgi in "${UI_DIR}/backend/garbage.cgi" \
           "${UI_DIR}/backend/empty.cgi" \
           "${UI_DIR}/backend/getIP.cgi"; do
    chmod +x "$cgi" && \
        log_message "Set +x on $(basename $cgi)" || \
        log_message "Warning: Could not chmod $(basename $cgi)"
done

# Set execute permission on httpd.py
chmod +x "${PKG_DEST}/bin/httpd.py" && \
    log_message "Set +x on bin/httpd.py" || \
    log_message "Warning: Could not chmod bin/httpd.py"

log_message "Post-installation completed successfully"
echo >> "$LOG_FILE"
exit 0
